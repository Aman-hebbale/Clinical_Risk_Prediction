# Copy this file to .env and fill in the values before running.
# Never commit .env to version control.

# PostgreSQL connection string used by the application and SQLAlchemy.
DATABASE_URL=postgresql://postgres:secret@localhost:5432/medpredict

# Password for the PostgreSQL superuser. Referenced by docker-compose.yml.
POSTGRES_PASSWORD=secret

# MLflow tracking server address. The training script logs all runs here.
MLFLOW_TRACKING_URI=http://localhost:5000

# Path to the serialised model file loaded by the API at startup.
# The training script writes models to the same directory (models/).
MODEL_PATH=models/best_model.pkl

# Uvicorn bind address and port (used by medpredict-serve / start.sh).
HOST=0.0.0.0
PORT=8000
